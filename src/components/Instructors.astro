---
import { instructors } from "../data/instructors";
---

<section class="instructors">

  <div class="container">

    <div class="section-header">

      <span class="section-badge">
        اساتید آموزشگاه
      </span>

      <h2>
        تیم حرفه‌ای مدرسین موسیقی
      </h2>

      <p>
        آموزش توسط اساتید با تجربه در حوزه موسیقی کلاسیک و مدرن
      </p>

    </div>

    <div class="instructors-grid">

      {instructors.map((ins) => (

        <article class="instructor-card">

          <div class="instructor-image">

            <img
              src={ins.image}
              alt={ins.name}
              loading="lazy"
            />

            {ins.id === 1 && (
              <span class="badge">
                مدیر آموزشگاه
              </span>
            )}

          </div>

          <div class="instructor-content">

            <h3>{ins.name}</h3>

            <p>{ins.position}</p>

            <a
              href={`/instructors/${ins.slug}`}
              class="profile-link"
            >
              مشاهده پروفایل →
            </a>

          </div>

        </article>

      ))}

    </div>

  </div>

</section>