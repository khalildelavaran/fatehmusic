---
import { courses } from "../data/courses";
import { instructors } from "../data/instructors";
import { schedules } from "../data/schedule";

/* -------------------------------------------------
   Course Cards
   Multi Instructor Compatible Schema
-------------------------------------------------- */

const courseCards = courses.map((course) => {

  /*
    پشتیبانی از هر دو ساختار:

    قدیمی:
    instructor: "teacher-id"

    جدید:
    instructors: [
      "teacher-id-1",
      "teacher-id-2"
    ]
  */

  const instructorIds = Array.isArray(course.instructors)
    ? course.instructors
    : course.instructor
      ? [course.instructor]
      : [];


  const courseInstructors = instructors.filter(
    (i) => instructorIds.includes(i.id)
  );


  const courseSchedules = schedules.filter(
    (s) =>
      s.active &&
      instructorIds.includes(s.instructorId)
  );


  const days = [
    ...new Set(
      courseSchedules.map((s) => s.weekday)
    )
  ];


  return {
    ...course,

    instructors: courseInstructors,

    schedules: courseSchedules,

    days
  };

});
---


<section
  class="courses"
  data-reveal="fade-up"
>

  <div class="container">


    <!-- ===========================
         Section Header
    ============================ -->

    <div
      class="section-header"
      data-reveal-group
    >

      <span
        class="section-badge"
        data-reveal
        data-reveal-delay="1"
      >
        دوره‌های آموزشی
      </span>


      <h2
        data-reveal
        data-reveal-delay="2"
      >
        یادگیری موسیقی با بهترین اساتید
      </h2>


      <p
        data-reveal
        data-reveal-delay="3"
      >
        دوره‌های آموزشی برای تمامی سنین، از مبتدی تا پیشرفته.
      </p>


    </div>



    <!-- ===========================
         Course Cards
    ============================ -->


    <div
      class="courses-grid"
      data-reveal-group
    >


      {courseCards.map((course) => (


        <a
          href={`/courses/${course.slug}`}
          class="course-card"
        >


          <div class="course-image">


            <img
              src={course.media.image}
              alt={course.title}
              loading="lazy"
              decoding="async"
            />


          </div>



          <div class="course-content">


            <h3>

              {course.title}

            </h3>



            <span class="course-subtitle">

              {course.content.excerpt}

            </span>





            <!-- ===========================
                 Multiple Instructors
            ============================ -->


            {course.instructors.length > 0 && (


              <div class="course-instructors">


                {course.instructors.map((instructor) => (


                  <div class="course-instructor">

                    {instructor.name}

                  </div>


                ))}


              </div>


            )}






            <!-- ===========================
                 Course Days
            ============================ -->


            {course.days.length > 0 && (


              <div class="days-tags">


                {course.days.map((day) => (


                  <span
                    class="day-tag"
                    aria-label={`روز برگزاری ${day}`}
                  >

                    {day}

                  </span>


                ))}


              </div>


            )}



          </div>



        </a>



      ))}


    </div>



  </div>



</section>