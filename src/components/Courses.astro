---
import { courses } from "../data/courses";
---

<section
  class="courses"
  data-reveal="fade-up"
>

  <div class="container">

    <!-- Section Header -->

    <div
      class="section-header"
      data-reveal-group
    >

      <span
        class="section-badge"
        data-reveal
        data-reveal-delay="1"
      >
        دوره‌های آموزشی
      </span>

      <h2
        data-reveal
        data-reveal-delay="2"
      >
        یادگیری موسیقی با بهترین اساتید
      </h2>

      <p
        data-reveal
        data-reveal-delay="3"
      >
        دوره‌های آموزشی برای تمامی سنین، از مبتدی تا پیشرفته.
      </p>

    </div>

    <!-- Courses -->

    <div
      class="courses-grid"
      data-reveal-group
    >

      {courses.map((course) => (

        <article class="course-card">

          <div class="course-image">

            <img
              src={course.image}
              alt={course.title}
              loading="lazy"
              decoding="async"
            />

          </div>

          <div class="course-content">

            <h3>

              {course.title}

            </h3>

            <span class="course-subtitle">

              {course.subtitle}

            </span>

            <a
              href={`/courses/${course.slug}`}
              class="course-link"
            >

              اطلاعات بیشتر

              <span>

                ←

              </span>

            </a>

          </div>

        </article>

      ))}

    </div>

  </div>

</section>