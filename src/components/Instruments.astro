---
import { instruments } from "../data/instruments1.js1";
---

<section
    class="instruments"
    data-reveal="fade-up"
>
    <div class="container">

        <div
            class="section-header"
            data-reveal-group
        >

            <span
                class="section-badge"
                data-reveal
                data-reveal-delay="1"
            >
                سازهای آموزشی
            </span>

            <h2
                data-reveal
                data-reveal-delay="2"
            >
                ساز مورد علاقه خود را انتخاب کنید
            </h2>

            <p
                data-reveal
                data-reveal-delay="3"
            >
                آموزش تخصصی انواع سازهای ایرانی و بین‌المللی در آموزشگاه موسیقی فاتح
            </p>

        </div>

        <div
            class="instruments-grid"
            data-reveal-group
        >

            {instruments.map((item, index) => (

                <article
                    class="instrument-card"
                    data-reveal
                    data-reveal-delay={index + 1}
                >

                    <div class="instrument-icon">
                        <i class={item.icon}></i>
                    </div>

                    <div class="instrument-content">

                        <h3>
                            {item.name}
                        </h3>

                        <p>
                            {item.content.excerpt}
                        </p>

                    </div>

                </article>

            ))}

        </div>

    </div>

</section>