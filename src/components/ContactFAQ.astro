---
import "../styles/ContactFAQ.css";

const faqs = [

    {
        question: "آیا قبل از ثبت‌نام امکان مشاوره وجود دارد؟",
        answer:
            "بله. پیش از ثبت‌نام می‌توانید به‌صورت حضوری یا تلفنی با آموزشگاه ارتباط بگیرید و درباره انتخاب ساز، سطح آموزشی و دوره مناسب مشاوره رایگان دریافت کنید."
    },

    {
        question: "آیا برای شروع آموزش به پیش‌زمینه موسیقی نیاز دارم؟",
        answer:
            "خیر. کلاس‌ها از سطح کاملاً مبتدی تا پیشرفته برگزار می‌شوند و هیچ پیش‌نیازی برای هنرجویان مبتدی وجود ندارد."
    },

    {
        question: "چه سازهایی در آموزشگاه تدریس می‌شوند؟",
        answer:
            "گیتار، پیانو، ویولن، تار، سه‌تار، دف، تنبک، سنتور، آواز و سایر سازهای ایرانی و جهانی توسط اساتید مجرب آموزش داده می‌شوند."
    },

    {
        question: "آیا امکان تعیین زمان کلاس وجود دارد؟",
        answer:
            "بله. زمان کلاس‌ها تا حد امکان با توجه به برنامه هنرجو و ظرفیت آموزشگاه هماهنگ می‌شود."
    },

    {
        question: "برای ثبت‌نام چه مدارکی لازم است؟",
        answer:
            "تنها ارائه اطلاعات هویتی و تکمیل فرم ثبت‌نام کافی است. در صورت نیاز، همکاران آموزشگاه راهنمایی‌های لازم را ارائه خواهند داد."
    }

];
---

<section class="contact-faq section">

    <div class="container">

        <div class="section-header">

            <span class="badge">

                سوالات متداول

            </span>

            <h2>

                پرسش‌های پرتکرار

            </h2>

            <p>

                پاسخ برخی از سوالاتی که هنرجویان پیش از ثبت‌نام بیشتر مطرح می‌کنند.

            </p>

        </div>

        <div class="faq-list">

            {

                faqs.map((faq) => (

                    <details class="card faq-item">

                        <summary>

                            {faq.question}

                        </summary>

                        <p>

                            {faq.answer}

                        </p>

                    </details>

                ))

            }

        </div>

    </div>

</section>