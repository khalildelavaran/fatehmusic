```astro
---
const gallery = [
  {
    title: "کلاس گیتار",
    subtitle: "آموزش گیتار کلاسیک، پاپ و فلامنکو",
    image: "/images/gallery/guitar.webp"
  },
  {
    title: "کلاس پیانو",
    subtitle: "آموزش پیانو کلاسیک و پاپ",
    image: "/images/gallery/piano.webp"
  },
  {
    title: "کلاس ویولون",
    subtitle: "آموزش ویولون ایرانی و کلاسیک",
    image: "/images/gallery/violin.webp"
  },
  {
    title: "اجرای هنرجویان",
    subtitle: "کنسرت‌ها و اجراهای پایان دوره",
    image: "/images/gallery/concert.webp"
  },
  {
    title: "موسیقی کودک",
    subtitle: "آموزش ویژه کودکان با متدهای نوین",
    image: "/images/gallery/kids.webp"
  },
  {
    title: "فضای آموزشگاه",
    subtitle: "محیط آموزشی مدرن و مجهز",
    image: "/images/gallery/academy.webp"
  }
];
---

<section
    id="gallery"
    class="gallery"
    data-reveal="fade-up"
>

    <div class="container">

        <!-- ================= HEADER ================= -->

        <div
            class="section-header"
            data-reveal-group
        >

            <span
                class="section-badge"
                data-reveal
                data-reveal-delay="1"
            >
                گالری آموزشگاه
            </span>

            <h2
                data-reveal
                data-reveal-delay="2"
            >
                لحظاتی از آموزش، تمرین و اجرا
            </h2>

            <p
                data-reveal
                data-reveal-delay="3"
            >
                تصاویری از کلاس‌ها، هنرجویان و فضای آموزشگاه موسیقی فاتح
            </p>

        </div>

        <!-- ================= GRID ================= -->

        <div
            class="gallery-grid"
            data-reveal-group
        >

            {gallery.map((item, index) => (

                <article

                    class="gallery-item"

                    data-reveal

                    data-reveal-delay={index + 1}

                    data-index={index}

                    data-image={item.image}

                    data-title={item.title}

                    data-subtitle={item.subtitle}

                    tabindex="0"

                    role="button"

                    aria-label={`مشاهده تصویر ${item.title}`}

                >

                    <img
                        src={item.image}
                        alt={item.title}
                        loading="lazy"
                        decoding="async"
                    />

                    <div class="gallery-overlay">

                        <h3>{item.title}</h3>

                        <p>{item.subtitle}</p>

                        <span class="gallery-link">

                            مشاهده تصویر

                            <span>←</span>

                        </span>

                    </div>

                </article>

            ))}

        </div>

    </div>

</section>

<!-- ================= LIGHTBOX ================= -->

<div

    id="lightbox"

    class="lightbox"

    role="dialog"

    aria-modal="true"

    aria-labelledby="lightbox-title"

    aria-describedby="lightbox-subtitle"

    aria-hidden="true"

>

    <button

        class="lightbox-close"

        aria-label="بستن"

        type="button"

    >

        ✕

    </button>

    <button

        class="lightbox-prev"

        aria-label="تصویر قبلی"

        type="button"

    >

        ❮

    </button>

    <div class="lightbox-content">

        <img

            id="lightbox-image"

            src=""

            alt=""

            loading="eager"

            decoding="sync"

        />

        <div class="lightbox-caption">

            <h3 id="lightbox-title"></h3>

            <p id="lightbox-subtitle"></p>

        </div>

    </div>

    <button

        class="lightbox-next"

        aria-label="تصویر بعدی"

        type="button"

    >

        ❯

    </button>

</div>
```
