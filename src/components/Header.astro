</a>


<a href="/teachers">
اساتید
</a>


<a href="/gallery">
گالری
</a>


<a href="/blog">
وبلاگ
</a>


<a href="/contact">
تماس
</a>


<a href="/register" class="mobile-register">

ثبت نام

</a>


</div>


</header>


<script>

const btn = document.getElementById("menuToggle");

const menu = document.getElementById("mobileMenu");


btn?.addEventListener("click",()=>{

menu?.classList.toggle("active");

});


</script>