<header class="header" id="siteHeader">

    <div class="container header-container">

        <!-- Logo -->

        <a
            href="/"
            class="logo"
            aria-label="آموزشگاه موسیقی فاتح"
        >

            <img
                src="/images/logo.webp"
                alt="آموزشگاه موسیقی فاتح"
                width="64"
                height="64"
                decoding="async"
            />

            <div class="logo-text">

                <h1>

                    آموزشگاه موسیقی فاتح

                </h1>

                <span>

                    آموزش تخصصی موسیقی

                </span>

            </div>

        </a>

        <!-- Desktop Navigation -->

        <nav
            class="desktop-menu"
            aria-label="منوی اصلی"
        >

            <ul class="menu">

                <li>

                    <a
                        href="/"
                        class="active"
                    >

                        خانه

                    </a>

                </li>

                <li>

                    <a href="/courses">

                        دوره‌ها

                    </a>

                </li>

                <li>

                    <a href="/teachers">

                        اساتید

                    </a>

                </li>

                <li>

                    <a href="/gallery">

                        گالری

                    </a>

                </li>

                <li>

                    <a href="/blog">

                        وبلاگ

                    </a>

                </li>

                <li>

                    <a href="/contact">

                        تماس با ما

                    </a>

                </li>

            </ul>

        </nav>

        <!-- Register -->

        <a
            href="/register"
            class="header-register"
        >

            ثبت نام

        </a>

        <!-- Mobile Button -->

        <button
            id="menuToggle"
            class="mobile-toggle"
            aria-label="باز کردن منو"
            aria-expanded="false"
            aria-controls="mobileMenu"
        >

            <!-- MENU -->

            <svg
                class="menu-icon"
                viewBox="0 0 24 24"
            >

                <path
                    d="M3 6H21M3 12H21M3 18H21"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.2"
                    stroke-linecap="round"
                />

            </svg>

            <!-- CLOSE -->

            <svg
                class="close-icon"
                viewBox="0 0 24 24"
            >

                <path
                    d="M6 6L18 18M18 6L6 18"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.2"
                    stroke-linecap="round"
                />

            </svg>

        </button>

    </div>

    <!-- Mobile Menu -->

    <nav
        id="mobileMenu"
        class="mobile-menu"
        aria-label="منوی موبایل"
    >

        <a href="/">

            خانه

        </a>

        <a href="/courses">

            دوره‌ها

        </a>

        <a href="/teachers">

            اساتید

        </a>

        <a href="/gallery">

            گالری

        </a>

        <a href="/blog">

            وبلاگ

        </a>

        <a href="/contact">

            تماس با ما

        </a>

        <a
            href="/register"
            class="mobile-register"
        >

            ثبت نام

        </a>

    </nav>

</header>


<script is:inline>

document.addEventListener("astro:page-load", () => {

    const header = document.getElementById("siteHeader");
    const toggle = document.getElementById("menuToggle");
    const menu = document.getElementById("mobileMenu");

    if (!header || !toggle || !menu) return;

    /* ===============================
       HEADER SCROLL
    =============================== */

    const updateHeader = () => {

        header.classList.toggle(
            "scrolled",
            window.scrollY > 20
        );

    };

    updateHeader();

    window.addEventListener(
        "scroll",
        updateHeader,
        { passive: true }
    );

    /* ===============================
       MOBILE MENU
    =============================== */

    const closeMenu = () => {

        toggle.classList.remove("active");

        menu.classList.remove("open");

        document.body.classList.remove("menu-open");

        toggle.setAttribute(
            "aria-expanded",
            "false"
        );

    };

    const openMenu = () => {

        toggle.classList.add("active");

        menu.classList.add("open");

        document.body.classList.add("menu-open");

        toggle.setAttribute(
            "aria-expanded",
            "true"
        );

    };

    toggle.addEventListener("click", () => {

        if (menu.classList.contains("open")) {

            closeMenu();

        } else {

            openMenu();

        }

    });

    /* ===============================
       CLICK OUTSIDE
    =============================== */

    document.addEventListener("click", (e) => {

        if (

            !menu.contains(e.target) &&

            !toggle.contains(e.target)

        ) {

            closeMenu();

        }

    });

    /* ===============================
       ESC
    =============================== */

    document.addEventListener("keydown", (e) => {

        if (e.key === "Escape") {

            closeMenu();

        }

    });

    /* ===============================
       CLOSE AFTER CLICK
    =============================== */

    menu.querySelectorAll("a").forEach((link) => {

        link.addEventListener("click", () => {

            closeMenu();

        });

    });

});

</script>