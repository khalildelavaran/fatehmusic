---
import MainLayout from "../layouts/MainLayout.astro";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import CTA from "../components/CTA.astro";
---

<MainLayout
    title="تماس با آموزشگاه موسیقی فاتح"
    description="راه‌های ارتباط با آموزشگاه موسیقی فاتح شوشتر، آدرس، شماره تماس، واتساپ و فرم ارسال پیام."
>

    <Header />

    <PageHero
        badge="تماس با ما"
        title="ارتباط با آموزشگاه موسیقی فاتح"
        description="برای مشاوره، ثبت‌نام یا دریافت اطلاعات کلاس‌ها با ما در ارتباط باشید."
    />

    <section class="contact-page">

        <div class="container">

            <div class="contact-grid">

                <div class="contact-info">

                    <h2>اطلاعات تماس</h2>

                    <div class="contact-item">

                        <strong>📍 آدرس</strong>

                        <p>
                            شوشتر
                        </p>

                    </div>

                    <div class="contact-item">

                        <strong>📞 تلفن</strong>

                        <p>
                            061-XXXXXXX
                        </p>

                    </div>

                    <div class="contact-item">

                        <strong>📱 موبایل</strong>

                        <p>
                            09XXXXXXXXX
                        </p>

                    </div>

                    <div class="contact-item">

                        <strong>✉ ایمیل</strong>

                        <p>
                            info@fatehmusic.ir
                        </p>

                    </div>

                </div>

                <div class="contact-form">

                    <h2>ارسال پیام</h2>

                    <form>

                        <input
                            type="text"
                            placeholder="نام و نام خانوادگی"
                            required
                        />

                        <input
                            type="tel"
                            placeholder="شماره تماس"
                            required
                        />

                        <input
                            type="email"
                            placeholder="ایمیل (اختیاری)"
                        />

                        <textarea
                            rows="6"
                            placeholder="متن پیام"
                            required
                        ></textarea>

                        <button
                            class="btn btn-primary"
                            type="submit"
                        >
                            ارسال پیام
                        </button>

                    </form>

                </div>
                </div>

            </div>

        </div>

    </section>

    <CTA />

    <Footer />

</MainLayout>

<style>

.contact-page{

    padding:80px 0;

}

.contact-grid{

    display:grid;

    grid-template-columns:1fr 1fr;

    gap:48px;

    align-items:start;

}

.contact-info,

.contact-form{

    background:#fff;

    border-radius:20px;

    padding:32px;

    box-shadow:0 10px 30px rgba(0,0,0,.08);

}

.contact-info h2,

.contact-form h2{

    margin-bottom:24px;

}

.contact-item{

    margin-bottom:24px;

}

.contact-item strong{

    display:block;

    margin-bottom:8px;

}

.contact-form form{

    display:flex;

    flex-direction:column;

    gap:16px;

}

.contact-form input,

.contact-form textarea{

    width:100%;

    padding:14px 16px;

    border:1px solid #ddd;

    border-radius:12px;

    font-family:inherit;

    font-size:1rem;

}

.contact-form textarea{

    resize:vertical;

}

.contact-form button{

    align-self:flex-start;

}

@media (max-width:768px){

    .contact-grid{

        grid-template-columns:1fr;

    }

}

</style>