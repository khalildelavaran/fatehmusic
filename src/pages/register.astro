---
import MainLayout from "../layouts/MainLayout.astro";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import CTA from "../components/CTA.astro";
---

<MainLayout
    title="ثبت نام کلاس‌های آموزشگاه موسیقی فاتح"
    description="ثبت نام آنلاین کلاس‌های گیتار، پیانو، ویولون، دف، هنگ درام، موسیقی کودک و سایر دوره‌های آموزشگاه موسیقی فاتح."
>

    <Header />

    <PageHero
        badge="ثبت نام"
        title="فرم ثبت نام کلاس‌ها"
        description="فرم زیر را تکمیل کنید تا کارشناسان آموزشگاه در اولین فرصت با شما تماس بگیرند."
    />

    <section class="register-page">

        <div class="container">

            <div class="register-card">

                <h2>فرم درخواست ثبت نام</h2>

                <form class="register-form">

                    <div class="form-grid">

                        <div>

                            <label>نام و نام خانوادگی</label>

                            <input
                                type="text"
                                required
                            />

                        </div>

                        <div>

                            <label>شماره موبایل</label>

                            <input
                                type="tel"
                                required
                            />

                        </div>

                        <div>

                            <label>سن</label>

                            <input
                                type="number"
                                min="3"
                                max="99"
                            />

                        </div>

                        <div>

                            <label>ساز مورد علاقه</label>

                            <select>

                                <option>گیتار</option>

                                <option>پیانو</option>

                                <option>ویولون</option>

                                <option>دف</option>

                                <option>هنگ درام</option>

                                <option>موسیقی کودک</option>

                                <option>تئوری موسیقی</option>

                            </select>

                        </div>
                        <div>

                            <label>سطح هنرجو</label>

                            <select>

                                <option>مبتدی</option>

                                <option>متوسط</option>

                                <option>پیشرفته</option>

                            </select>

                        </div>

                        <div>

                            <label>روزهای ترجیحی</label>

                            <select>

                                <option>شنبه و دوشنبه</option>

                                <option>یکشنبه و سه‌شنبه</option>

                                <option>چهارشنبه و پنجشنبه</option>

                                <option>تفاوتی ندارد</option>

                            </select>

                        </div>

                    </div>

                    <div class="form-group">

                        <label>توضیحات</label>

                        <textarea
                            rows="6"
                            placeholder="در صورت نیاز توضیحات خود را وارد کنید..."
                        ></textarea>

                    </div>

                    <button
                        class="btn btn-primary"
                        type="submit"
                    >
                        ثبت درخواست
                    </button>

                </form>

            </div>

        </div>

    </section>

    <CTA />

    <Footer />

</MainLayout>

<style>

.register-page{

    padding:80px 0;

}

.register-card{

    max-width:900px;

    margin:auto;

    background:#fff;

    border-radius:20px;

    padding:40px;

    box-shadow:0 12px 32px rgba(0,0,0,.08);

}

.register-card h2{

    margin-bottom:32px;

    text-align:center;

}

.register-form{

    display:flex;

    flex-direction:column;

    gap:24px;

}

.form-grid{

    display:grid;

    grid-template-columns:repeat(2,1fr);

    gap:24px;

}

.form-group{

    display:flex;

    flex-direction:column;

    gap:10px;

}

.form-grid>div{

    display:flex;

    flex-direction:column;

    gap:10px;

}

.register-form label{

    font-weight:600;

}

.register-form input,

.register-form select,

.register-form textarea{

    width:100%;

    padding:14px 16px;

    border:1px solid #d8d8d8;

    border-radius:12px;

    font:inherit;

    transition:.25s;

}

.register-form input:focus,

.register-form select:focus,

.register-form textarea:focus{

    outline:none;

    border-color:var(--color-primary,#b8860b);

    box-shadow:0 0 0 3px rgba(184,134,11,.15);

}

.register-form textarea{

    resize:vertical;

}

.register-form button{

    align-self:flex-start;

}

@media (max-width:768px){

    .register-card{

        padding:24px;

    }

    .form-grid{

        grid-template-columns:1fr;

    }

    .register-form button{

        width:100%;

    }

}

</style>