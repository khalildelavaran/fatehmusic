---
import MainLayout from "../layouts/MainLayout.astro";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import CTA from "../components/CTA.astro";

import { contact } from "../data/contact";
---

<MainLayout
    title="ثبت نام کلاس‌های آموزشگاه موسیقی فاتح"
    description="ثبت نام آنلاین کلاس‌های گیتار، پیانو، ویولون، دف، هنگ درام، موسیقی کودک و سایر دوره‌های آموزشگاه موسیقی فاتح."
>

    <Header />

    <PageHero
        badge="ثبت نام"
        title="فرم ثبت نام کلاس‌ها"
        description="فرم زیر را تکمیل کنید تا کارشناسان آموزشگاه در اولین فرصت با شما تماس بگیرند."
    />

    <section class="register-page">

        <div class="container">

            <div class="card register-card">

                <h2>فرم درخواست ثبت نام</h2>

                <form id="registerForm" class="register-form">

                    <div class="form-grid">

                        <div>

                            <label for="fullName">نام و نام خانوادگی</label>

                            <input
                                type="text"
                                id="fullName"
                                name="fullName"
                                autocomplete="name"
                                required
                            />

                        </div>

                        <div>

                            <label for="phone">شماره موبایل</label>

                            <input
                                type="tel"
                                id="phone"
                                name="phone"
                                autocomplete="tel"
                                pattern="09[0-9]{9}"
                                placeholder="09xxxxxxxxx"
                                required
                            />

                        </div>

                        <div>

                            <label for="age">سن</label>

                            <input
                                type="number"
                                id="age"
                                name="age"
                                min="3"
                                max="99"
                            />

                        </div>

                        <div>

                            <label for="instrument">ساز مورد علاقه</label>

                            <select id="instrument" name="instrument">

                                <option>گیتار</option>

                                <option>پیانو</option>

                                <option>ویولون</option>

                                <option>دف</option>

                                <option>هنگ درام</option>

                                <option>موسیقی کودک</option>

                                <option>تئوری موسیقی</option>

                            </select>

                        </div>
                        <div>

                            <label for="level">سطح هنرجو</label>

                            <select id="level" name="level">

                                <option>مبتدی</option>

                                <option>متوسط</option>

                                <option>پیشرفته</option>

                            </select>

                        </div>

                        <div>

                            <label for="preferredDays">روزهای ترجیحی</label>

                            <select id="preferredDays" name="preferredDays">

                                <option>شنبه و دوشنبه</option>

                                <option>یکشنبه و سه‌شنبه</option>

                                <option>چهارشنبه و پنجشنبه</option>

                                <option>تفاوتی ندارد</option>

                            </select>

                        </div>

                    </div>

                    <div class="form-group">

                        <label for="notes">توضیحات</label>

                        <textarea
                            id="notes"
                            name="notes"
                            rows="6"
                            placeholder="در صورت نیاز توضیحات خود را وارد کنید..."
                        ></textarea>

                    </div>

                    <button
                        class="btn btn-primary"
                        type="submit"
                    >
                        ثبت درخواست
                    </button>

                    <p
                        id="registerStatus"
                        class="register-status"
                        role="status"
                    ></p>

                </form>

            </div>

        </div>

    </section>

    <CTA />

    <Footer />

</MainLayout>

<style>

.register-page{

    padding:15px 0;

}

.register-card{

    max-width:900px;

    margin:auto;

    padding:40px;

}

.register-card h2{

    margin-bottom:32px;

    text-align:center;

}

.register-form{

    display:flex;

    flex-direction:column;

    gap:24px;

}

.form-grid{

    display:grid;

    grid-template-columns:repeat(2,1fr);

    gap:24px;

}

.form-group{

    display:flex;

    flex-direction:column;

    gap:10px;

}

.form-grid>div{

    display:flex;

    flex-direction:column;

    gap:10px;

}

.register-form label{

    font-weight:600;

}

.register-form input,

.register-form select,

.register-form textarea{

    width:100%;

    padding:14px 16px;

    border:1px solid var(--border);

    border-radius:12px;

    background:var(--surface);

    color:var(--text);

    font:inherit;

    transition:.25s;

}

.register-form input:focus,

.register-form select:focus,

.register-form textarea:focus{

    outline:none;

    border-color:var(--primary);

    box-shadow:0 0 0 3px rgba(201,162,39,.2);

}

.register-form textarea{

    resize:vertical;

}

.register-form button{

    align-self:flex-start;

}

.register-status{

    font-size:.9rem;

    color:var(--primary);

    min-height:1.2em;

}

@media (max-width:768px){

    .register-card{

        padding:24px;

    }

    .form-grid{

        grid-template-columns:1fr;

    }

    .register-form button{

        width:100%;

    }

}

</style>

<script define:vars={{ whatsappNumber: contact.phones.mobile.raw }}>
    const form = document.getElementById("registerForm");
    const status = document.getElementById("registerStatus");

    form?.addEventListener("submit", (event) => {
        event.preventDefault();

        if (!form.reportValidity()) {
            return;
        }

        const data = new FormData(form);
        const get = (key) => (data.get(key) || "").toString().trim();

        const fullName = get("fullName");
        const phone = get("phone");
        const age = get("age");
        const instrument = get("instrument");
        const level = get("level");
        const preferredDays = get("preferredDays");
        const notes = get("notes");

        const lines = [
            "ثبت‌نام جدید - آموزشگاه موسیقی فاتح",
            "",
            `نام و نام خانوادگی: ${fullName}`,
            `شماره موبایل: ${phone}`
        ];

        if (age) lines.push(`سن: ${age}`);
        if (instrument) lines.push(`ساز مورد علاقه: ${instrument}`);
        if (level) lines.push(`سطح هنرجو: ${level}`);
        if (preferredDays) lines.push(`روزهای ترجیحی: ${preferredDays}`);
        if (notes) lines.push(`توضیحات: ${notes}`);

        const message = lines.join("\n");
        const url = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(message)}`;

        if (status) {
            status.textContent = "در حال انتقال به واتساپ برای ارسال درخواست...";
        }

        window.open(url, "_blank", "noopener,noreferrer");
        form.reset();
    });
</script>